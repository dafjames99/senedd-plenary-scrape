DATABASE_URL="sqlite:///./sqlite_database.db" #Boilerplate sqlite db URL; replace with own DB url. E.g. for postgres: "postgresql://user:password@localhost/dbname"

# Read-only consumer role (MCP + web app). DATABASE_URL above is the owner/write
# role used by the pipeline. `make provision` creates a SELECT-only login role
# (READONLY_DB_ROLE, default senedd_ro) with password READONLY_DB_PASSWORD. Set
# DATABASE_URL_RO to that role's URL; the MCP uses it via settings.read_database_url
# (falls back to DATABASE_URL when unset). The Next.js app is configured separately
# in apps/web/.env. Postgres only — ignored for sqlite dev.
# READONLY_DB_ROLE="senedd_ro"
# READONLY_DB_PASSWORD="change-me"
# DATABASE_URL_RO="postgresql+psycopg2://senedd_ro:change-me@localhost:5432/dbname"

EMBED_BATCH_SIZE=250
EMBEDDING_PROVIDER="sentence-transformer" # One of: sentence-transformer, openai, ollama [#TODO: MORE?]
EMBEDDING_MODEL="all-MiniLM-L6-v2" # The model to use for embeddings; adjust based on provider. E.g. for OpenAI: "text-embedding-3-small"

OLLAMA_URL="http://localhost:11434" # URL for Ollama server; adjust if using a different host/port or if Ollama is not used.

HF_TOKEN="secret_key_here" # Hugging Face token for private models; not needed for public models. Replace with your actual token if using private models.
OPENAI_API_KEY=""
SECRET_KEY="your_secret_key_here" # Replace with a secure random string for production

DEBUG=True # Set to False in production
ALLOWED_HOSTS=["*"] # Update with your domain in production
LOG_LEVEL="INFO" # Adjust log level as needed (e.g., DEBUG, INFO, WARNING, ERROR, CRITICAL)