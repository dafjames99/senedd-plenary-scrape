DATABASE_URL="sqlite:///./sqlite_database.db" # Boilerplate sqlite db URL; replace with own DB url. E.g. for postgres: "postgresql://user:password@localhost/dbname"
EMBEDDING_PROVIDER="sentence-transformer" # One of: sentence-transformer, openai, ollama [#TODO: MORE?]
EMBEDDING_MODEL="all-MiniLM-L6-v2" # The model to use for embeddings; adjust based on provider. E.g. for OpenAI: "text-embedding-3-small"
SECRET_KEY="your_secret_key_here" # Replace with a secure random string for production
DEBUG=True # Set to False in production
ALLOWED_HOSTS=["*"] # Update with your domain in production
LOG_LEVEL="INFO" # Adjust log level as needed (e.g., DEBUG, INFO, WARNING, ERROR, CRITICAL)