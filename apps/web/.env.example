# Postgres connection — the web app is a read-only consumer, so point this at
# the SELECT-only `senedd_ro` role provisioned by `make provision` (never the
# pipeline's owner role). Use the plain `postgresql://` scheme: this is Node/pg,
# NOT SQLAlchemy — do not carry over the `+psycopg2` dialect from the root .env,
# pg won't understand it. Swapping local dev -> Neon is exactly this one
# variable (use Neon's pooled connection string).
DATABASE_URL=postgresql://senedd_ro:<password>@localhost:5432/senedd_db

# Video pane behaviour: embed | link | off  (see apps/web/PRD.md §2)
#   embed - iframe the SeneddTV clip (default)
#   link  - no iframe; transcript takes the whole right-hand side, speeches
#           keep "watch on Senedd.tv" external links
NEXT_PUBLIC_VIDEO_MODE=embed

# LLM ask-box. Without ANTHROPIC_API_KEY the /api/ask route runs in mock mode
# (deterministic answer built from real DB rows, clearly labelled in the UI).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
# MCP server (HTTP transport): make mcp-http  ->  http://localhost:8000/mcp
# SENEDD_MCP_URL=http://localhost:8000/mcp
